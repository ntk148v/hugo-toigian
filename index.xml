&lt;/figure&gt;
&lt;/td&gt;
 &lt;td&gt;&lt;figure class="figure"&gt;&lt;img src="https://raw.githubusercontent.com/ntk148v/hugo-toigian/master/images/light-list.png"&gt;
&lt;/figure&gt;
